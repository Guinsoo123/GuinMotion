{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-ninja",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/.deps/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/vcpkg-triplets",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/cmake/vcpkg-ports",
        "VCPKG_TARGET_TRIPLET": "$env{VCPKG_DEFAULT_TRIPLET}",
        "GUINMOTION_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "default",
      "displayName": "Qt desktop (RelWithDebInfo)",
      "inherits": "base-ninja",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "GUINMOTION_ENABLE_QT": "ON"
      }
    },
    {
      "name": "headless",
      "displayName": "No Qt / CLI only",
      "inherits": "base-ninja",
      "binaryDir": "${sourceDir}/build/headless",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "GUINMOTION_ENABLE_QT": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release package (Qt)",
      "inherits": "base-ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "GUINMOTION_ENABLE_QT": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "headless",
      "configurePreset": "headless"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ]
}
