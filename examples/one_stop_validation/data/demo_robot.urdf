<?xml version="1.0"?>
<robot name="demo_validation_robot">
  <material name="base_gray"><color rgba="0.65 0.68 0.72 1"/></material>
  <material name="arm_blue"><color rgba="0.25 0.45 0.95 1"/></material>
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.20 0.20 0.08"/></geometry>
      <material name="base_gray"/>
    </visual>
  </link>
  <link name="link_1">
    <visual>
      <origin xyz="0.12 0 0" rpy="0 0 0"/>
      <geometry><box size="0.24 0.04 0.04"/></geometry>
      <material name="arm_blue"/>
    </visual>
  </link>
  <link name="link_2">
    <visual>
      <origin xyz="0.12 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/tool.obj"/></geometry>
      <material name="arm_blue"/>
    </visual>
  </link>
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" velocity="1.5" effort="10"/>
  </joint>
  <joint name="joint_2" type="prismatic">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0.24 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.6" upper="0.6" velocity="0.5" effort="10"/>
  </joint>
  <joint name="joint_3" type="prismatic">
    <parent link="link_2"/>
    <child link="tool0"/>
    <origin xyz="0.12 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6" upper="0.6" velocity="0.5" effort="10"/>
  </joint>
</robot>
